<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — NBA Analytics</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #121212; color: #ffffff; }
        .sidebar { min-height: 100vh; background-color: #1a1a2e; padding-top: 20px; }
        .sidebar a { color: #cccccc; text-decoration: none; display: block; padding: 8px 16px; border-radius: 5px; }
        .sidebar a:hover { background-color: #e94560; color: white; }
        .sidebar .section-title { color: #e94560; font-weight: bold; padding: 10px 16px; font-size: 12px; text-transform: uppercase; }
        .main-content { padding: 30px; }
        .navbar-brand { color: #e94560 !important; font-weight: bold; font-size: 22px; }
    </style>
</head>
<body>
    <!-- Top navbar -->
    <nav class="navbar navbar-dark" style="background-color:#0f3460;">
        <div class="container-fluid">
            <span class="navbar-brand">🏀 NBA Analytics</span>
            <a href="/Admin/Login" class="btn btn-outline-light btn-sm">Admin</a>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-2 sidebar">
                <div class="section-title">Teams</div>
                <a href="/Teams">📊 League Standings</a>
                <a href="/Teams/Conference">🌍 By Conference</a>
                <a href="/Teams/Payroll">💰 By Payroll</a>

                <div class="section-title mt-3">Players</div>
                <a href="/Players">🏀 Top Scorers</a>
                <a href="/Players/Assists">🎯 Top Assisters</a>
                <a href="/Players/Rebounds">💪 Top Rebounders</a>
                <a href="/Players/Steals">🦅 Top Stealers</a>
                <a href="/Players/Blocks">🛡️ Top Blockers</a>
                <a href="/Players/Salaries">💵 Top Salaries</a>
            </div>

            <!-- Main content -->
            <div class="col-md-10 main-content">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
