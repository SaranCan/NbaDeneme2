@model IEnumerable<NbaDeneme2.Models.VwTopSalary>

@{
    ViewData["Title"] = "Top Salaries";
}

<h2 class="mb-4">💵 Top 10 Salaries</h2>

<table class="table table-dark table-striped table-hover">
    <thead>
        <tr>
            <th>Rank</th>
            <th>Player</th>
            <th>Team</th>
            <th>Salary</th>
        </tr>
    </thead>
   <tbody>
        @{ int rank = 1;
           foreach (var player in Model)
           { 
            <tr>
                <td>@rank</td>
                <td>@player.PlayerName</td>
                <td>@player.TeamName</td>
                <td>$@String.Format("{0:N0}", player.Salary)</td>
            </tr>
            rank++;
           }
        }
    </tbody>
</table>
