@model IEnumerable<NbaDeneme2.Models.VwTopScorersPpg>
@{ ViewData["Title"] = "Top Scorers"; }
<h2 class="mb-4">🏀 Top 10 Scorers</h2>
<table class="table table-dark table-striped table-hover">
    <thead><tr><th>Rank</th><th>Player</th><th>Team</th><th>PPG</th></tr></thead>
    <tbody>
        @{ int rank = 1;
           foreach (var player in Model) {
            <tr>
                <td>@rank</td>
                <td>@player.PlayerName</td>
                <td>@player.TeamName</td>
                <td>@player.Ppg</td>
            </tr>
            rank++;
           }
        }
    </tbody>
</table>
