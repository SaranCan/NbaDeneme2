@{
    ViewData["Title"] = "Conference Standings";
}

<h2 class="mb-4">🏀 Conference Standings</h2>

<div class="row">
    <div class="col-md-6">
        <h4 class="text-warning">Eastern Conference</h4>
        <table class="table table-dark table-striped table-hover">
            <thead>
                <tr>
                    <th>Rank</th>
                    <th>Team</th>
                    <th>W</th>
                    <th>L</th>
                    <th>Diff</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var team in ViewBag.East)
                {
                    <tr>
                        <td>@team.ConferenceRank</td>
                        <td>@team.TeamName</td>
                        <td>@team.Wins</td>
                        <td>@team.Loses</td>
                        <td>@team.Differential</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="col-md-6">
        <h4 class="text-info">Western Conference</h4>
        <table class="table table-dark table-striped table-hover">
            <thead>
                <tr>
                    <th>Rank</th>
                    <th>Team</th>
                    <th>W</th>
                    <th>L</th>
                    <th>Diff</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var team in ViewBag.West)
                {
                    <tr>
                        <td>@team.ConferenceRank</td>
                        <td>@team.TeamName</td>
                        <td>@team.Wins</td>
                        <td>@team.Loses</td>
                        <td>@team.Differential</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
